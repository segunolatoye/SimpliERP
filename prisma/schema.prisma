generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                   @id @default(uuid())
  email                  String                   @unique
  phone_number           String?
  phone_verified         Boolean                  @default(false)
  password_hash          String?
  mfa_secret             String?
  mfa_enabled            Boolean                  @default(false)
  mfa_type               String?
  mfa_phone              String?
  mfa_last_otp           String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  deleted_at             DateTime?
  is_superadmin          Boolean                  @default(false)
  audit_logs             AuditLog[]
  location_members       location_members[]
  locations              Location[]
  notifications          notifications[]
  org_members            org_members[]
  approval_requests      approval_requests[]
  approval_request_steps approval_request_steps[]

  @@index([deleted_at])
  @@map("users")
}

model Role {
  id                      String                    @id @default(uuid())
  org_id                  String
  name                    String
  description             String?
  permissions             Json
  is_system               Boolean                   @default(false)
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  deleted_at              DateTime?
  organisations           organisations             @relation(fields: [org_id], references: [id])
  approval_workflow_steps approval_workflow_steps[]

  @@unique([org_id, name])
  @@index([deleted_at])
  @@index([org_id, created_at])
  @@map("roles")
}

model AuditLog {
  id            String        @id @default(uuid())
  org_id        String
  user_id       String
  module        String
  action        String
  entity_type   String
  entity_id     String
  diff          Json?
  ip            String?
  user_agent    String?
  created_at    DateTime      @default(now())
  organisations organisations @relation(fields: [org_id], references: [id])
  users         User          @relation(fields: [user_id], references: [id])

  @@index([org_id, created_at])
  @@map("audit_logs")
}

model AccountingPeriod {
  id            String        @id @default(uuid())
  org_id        String
  name          String
  start_date    DateTime
  end_date      DateTime
  status        String        @default("open")
  created_at    DateTime      @default(now())
  updated_at    DateTime
  organisations organisations @relation(fields: [org_id], references: [id])

  @@unique([org_id, name])
  @@index([org_id, created_at])
  @@map("accounting_periods")
}

model Item {
  id                                            String                @id @default(uuid())
  org_id                                        String
  sku                                           String
  name                                          String
  description                                   String?
  category_id                                   String?
  unit_id                                       String?
  reorder_point                                 Int                   @default(0)
  preferred_vendor_id                           String?
  lead_time_days                                Int                   @default(0)
  cost_method                                   CostMethod            @default(fifo)
  created_at                                    DateTime              @default(now())
  updated_at                                    DateTime
  deleted_at                                    DateTime?
  brand                                         String?
  cost_price                                    Float                 @default(0)
  ean                                           String?
  height                                        Float?
  is_purchasable                                Boolean               @default(true)
  is_returnable                                 Boolean               @default(false)
  is_sellable                                   Boolean               @default(true)
  isbn                                          String?
  length                                        Float?
  manufacturer                                  String?
  mpn                                           String?
  purchase_description                          String?
  purchase_tax_id                               String?
  sales_description                             String?
  sales_tax_id                                  String?
  selling_price                                 Float                 @default(0)
  track_bin                                     Boolean               @default(false)
  track_inventory                               Boolean               @default(true)
  requires_physical_receipt                     Boolean               @default(true)
  type                                          String                @default("Goods")
  upc                                           String?
  weight                                        Float?
  width                                         Float?
  dimension_unit                                String?               @default("cm")
  weight_unit                                   String?               @default("kg")
  inventory_account_id                          String?
  purchase_account_id                           String?
  sales_account_id                              String?
  gst_rate                                      Float?
  hsn_sac_code                                  String?
  opening_stock_value                           Float?                @default(0)
  tax_preference                                String?               @default("Taxable")
  status                                        String                @default("Active")
  item_group_id                                 String?
  floor_price                                   Float?                @default(0)
  track_lot                                     Boolean               @default(false)
  track_serial                                  Boolean               @default(false)
  count_session_lines                           count_session_lines[]
  item_locations                                item_locations[]
  item_variants                                 item_variants[]
  vendor_bill_lines                             vendor_bill_lines[]
  item_categories                               item_categories?      @relation(fields: [category_id], references: [id])
  accounts_items_inventory_account_idToaccounts accounts?             @relation("items_inventory_account_idToaccounts", fields: [inventory_account_id], references: [id])
  item_groups                                   item_groups?          @relation(fields: [item_group_id], references: [id])
  organisations                                 organisations         @relation(fields: [org_id], references: [id])
  vendors                                       vendors?              @relation(fields: [preferred_vendor_id], references: [id])
  accounts_items_purchase_account_idToaccounts  accounts?             @relation("items_purchase_account_idToaccounts", fields: [purchase_account_id], references: [id])
  accounts_items_sales_account_idToaccounts     accounts?             @relation("items_sales_account_idToaccounts", fields: [sales_account_id], references: [id])
  units                                         units?                @relation(fields: [unit_id], references: [id])
  po_lines                                      po_lines[]
  sales_return_lines                            sales_return_lines[]
  so_lines                                      so_lines[]
  stock_adjustments                             stock_adjustments[]
  stock_ledger                                  stock_ledger[]
  delivery_note_lines                           delivery_note_lines[]
  invoice_lines                                 invoice_lines[]

  @@unique([org_id, sku])
  @@index([deleted_at])
  @@index([org_id, created_at])
  @@map("items")
}

model Location {
  id                                              String              @id @default(uuid())
  org_id                                          String
  name                                            String
  address                                         String?
  is_headquarters                                 Boolean             @default(false)
  location_type                                   String              @default("business")
  logo_url                                        String?
  phone                                           String?
  email                                           String?
  website                                         String?
  primary_contact_id                              String?
  transaction_prefix                              String?
  price_list_id                                   String?
  created_at                                      DateTime            @default(now())
  updated_at                                      DateTime
  deleted_at                                      DateTime?
  parent_id                                       String?
  count_sessions                                  count_sessions[]
  delivery_notes                                  delivery_notes[]
  goods_receipts                                  goods_receipts[]
  item_locations                                  item_locations[]
  location_members                                location_members[]
  organisations                                   organisations       @relation(fields: [org_id], references: [id])
  parent_location                                 Location?           @relation("LocationHierarchy", fields: [parent_id], references: [id])
  child_locations                                 Location[]          @relation("LocationHierarchy")
  price_lists                                     price_lists?        @relation(fields: [price_list_id], references: [id])
  users                                           User?               @relation(fields: [primary_contact_id], references: [id])
  stock_adjustments                               stock_adjustments[]
  stock_ledger                                    stock_ledger[]
  transfers_transfers_from_location_idTolocations transfers[]         @relation("transfers_from_location_idTolocations")
  transfers_transfers_to_location_idTolocations   transfers[]         @relation("transfers_to_location_idTolocations")

  @@unique([org_id, name])
  @@index([deleted_at])
  @@index([org_id, created_at])
  @@map("locations")
}

